# nginx/nginx.conf
# ============================================================
# Reverse proxy:
#   /          → frontend (static HTML)
#   /api/      → FastAPI backend
#   /docs      → FastAPI Swagger
#   /health    → FastAPI health check
# ============================================================

events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    # Logging
    log_format main '$remote_addr - $request - $status - $body_bytes_sent';
    access_log /var/log/nginx/access.log main;

    # Upload size limit (match MAX_PDF_SIZE_MB * MAX_PDF_FILES)
    client_max_body_size 100M;

    # Timeouts — important for long LLM streaming responses
    proxy_read_timeout    300s;
    proxy_connect_timeout 10s;
    proxy_send_timeout    300s;

    # Disable buffering for SSE streaming
    proxy_buffering off;

    upstream api {
        server app:8000;
        keepalive 32;
    }

    server {
        listen 80;
        server_name _;

        # ── Frontend ────────────────────────────────────────
        location / {
            root /usr/share/nginx/html;
            index index.html;
            try_files $uri $uri/ /index.html;
        }

        # ── API proxy ────────────────────────────────────────
        location ~ ^/(health|docs|redoc|openapi.json|documents|chat) {
            proxy_pass http://api;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header Connection '';   # keep-alive for SSE

            # SSE-specific — disable buffering for streaming responses
            proxy_cache off;
            proxy_buffering off;
            chunked_transfer_encoding on;
        }
    }
}